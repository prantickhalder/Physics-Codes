    "df = pd.read_csv(file_path, names=['N', 'Pi Values'], dtype={'Pi Values': float, 'N': float}, sep='\\s+')\n",
    "df. plot(x = 'N', y='Pi Values',kind='line', marker = 'o')\n",
    "plt.show()\n",
